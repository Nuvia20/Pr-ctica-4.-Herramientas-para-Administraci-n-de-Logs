<h2>Login</h2>

<form method="post">

    <input type="text"
           name="username"
           placeholder="Usuario" />

    <br /><br />

    <input type="password"
           name="password"
           placeholder="Contraseña" />

    <br /><br />

    <button type="submit">
        Entrar
    </button>

</form>

<p>@ViewBag.Error</p>